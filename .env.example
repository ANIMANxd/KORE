# Vector store (set by kore setup — do not edit manually)
KORE_DATA_DIR=~/.kore/data

# pgvector only (leave empty if using LanceDB)
DATABASE_URL=

# Extraction settings
MAX_JSON_RETRIES=3
# For cloud embeddings (OpenAI): 0.75 is typical
# For local embeddings (Ollama/LM Studio): try 0.35-0.50
SIMILARITY_THRESHOLD=0.40
MAX_CHUNKS_PER_QUERY=15
MIN_CONFIDENCE_THRESHOLD=0.6
HUMAN_REVIEW_THRESHOLD=0.85

# Slack live ingestion (optional — only needed for live API mode)
# Create a Slack app at https://api.slack.com/apps → OAuth & Permissions
# Add Bot Token Scopes: channels:history, channels:read, users:read
# Install to workspace, then copy the Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_IDS=C01234567,C09876543
SLACK_EARLIEST_DATE=2024-01-01

# GitHub live ingestion (optional — only needed for live API mode)
# Create a Personal Access Token at https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=ghp_your-github-token
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
GITHUB_EXTENSIONS=.py .md .yaml .yml .ts .js

# Notion live ingestion (optional — only needed for live API mode)
# Create an integration at https://www.notion.so/my-integrations
# Grant it access to each page you want to ingest (page → ... → Connections)
NOTION_TOKEN=ntn_your-notion-token

# Jira live ingestion (optional — only needed for live API mode)
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://company.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEYS=KAN,PROJ
