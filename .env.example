DATABASE_URL=postgresql://user:password@localhost:5432/kore
MAX_JSON_RETRIES=3
# For cloud embeddings (OpenAI): 0.75 is typical
# For local embeddings (Ollama/LM Studio): try 0.35-0.50
SIMILARITY_THRESHOLD=0.40
MAX_CHUNKS_PER_QUERY=15
MIN_CONFIDENCE_THRESHOLD=0.6
HUMAN_REVIEW_THRESHOLD=0.85

# Slack live ingestion (optional — only needed for live API mode)
# Create a Slack app at https://api.slack.com/apps → OAuth & Permissions
# Add Bot Token Scopes: channels:history, channels:read, users:read
# Install to workspace, then copy the Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_IDS=C01234567,C09876543
SLACK_EARLIEST_DATE=2024-01-01
